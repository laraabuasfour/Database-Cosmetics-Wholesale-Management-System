<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="466.0" prefWidth="600.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.VehicleInfoSaveController">
   <children>

      <!-- Page Title -->
      <Label alignment="CENTER" layoutX="140.0" layoutY="20.0" prefHeight="40.0" prefWidth="320.0" style="-fx-font-size: 20px; -fx-text-fill: #007BFF; -fx-font-weight: bold;" text="Add New Vehicle Information" textFill="#061736">
         <effect>
            <DropShadow color="#007BFF" radius="3.0" />
         </effect>
         <font>
            <Font size="20.0" />
         </font>
      </Label>

      <!-- Permit Number Field -->
      <Label alignment="CENTER" layoutX="125.0" layoutY="87.0" prefHeight="30.0" prefWidth="151.0" style="-fx-font-size: 20px; -fx-text-fill: #343a40;" text="Permit Number" textAlignment="CENTER">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <TextField fx:id="permitNumber" layoutX="332.0" layoutY="87.0" prefHeight="36.0" prefWidth="159.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Capacity Field -->
      <Label alignment="CENTER" layoutX="134.0" layoutY="140.0" prefHeight="30.0" prefWidth="82.0" style="-fx-font-size: 20px; -fx-text-fill: #343a40;" text="Capacity" textAlignment="CENTER">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <TextField fx:id="Vcapacity" layoutX="332.0" layoutY="137.0" prefHeight="36.0" prefWidth="159.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Vehicle Number Field -->
      <Label alignment="CENTER" layoutX="132.0" layoutY="195.0" prefHeight="30.0" prefWidth="151.0" style="-fx-font-size: 20px; -fx-text-fill: #343a40;" text="Vehicle Number" textAlignment="CENTER">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <TextField fx:id="vehnum" layoutX="331.0" layoutY="192.0" prefHeight="36.0" prefWidth="159.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Phone Number Field -->
      <Label alignment="CENTER" layoutX="134.0" layoutY="250.0" style="-fx-font-size: 20px; -fx-text-fill: #343a40;" text="Phone Number" textAlignment="CENTER">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <TextField fx:id="phoneNumber" layoutX="332.0" layoutY="247.0" prefHeight="36.0" prefWidth="159.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Employee ID Field -->
      <Label alignment="CENTER" layoutX="132.0" layoutY="305.0" prefHeight="30.0" prefWidth="122.0" style="-fx-font-size: 20px; -fx-text-fill: #343a40;" text="Employee ID" textAlignment="CENTER">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <TextField fx:id="empID" layoutX="331.0" layoutY="302.0" prefHeight="36.0" prefWidth="159.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Error Label -->
      <Label fx:id="errorLabel" layoutX="88.0" layoutY="357.0" prefHeight="30.0" prefWidth="422.0" style="-fx-text-fill: red; -fx-font-size: 15px;" textAlignment="CENTER">
         <font>
            <Font size="15.0" />
         </font>
      </Label>

      <!-- Buttons -->
      <Button fx:id="closeBtn" layoutX="163.0" layoutY="396.0" mnemonicParsing="false" onAction="#closeClicked" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="✖ Close" />
      <Button fx:id="saveBtn" layoutX="366.0" layoutY="396.0" mnemonicParsing="false" onAction="#save" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="💾 Save" />

   </children>
</AnchorPane>
