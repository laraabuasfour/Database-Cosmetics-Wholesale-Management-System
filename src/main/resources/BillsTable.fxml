<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="701.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.BillsTableController">
    <children>

        <!-- Centered Title -->
        <HBox layoutY="15.0" prefWidth="701.0" alignment="CENTER">
            <children>
                <Label text="💰 Bills Overview" style="-fx-font-size: 22px; -fx-text-fill: #007BFF; -fx-font-weight: bold;">
                    <font>
                        <Font size="22.0" />
                    </font>
                </Label>
            </children>
        </HBox>

        <!-- TableView -->
        <TableView fx:id="billsTable" layoutX="50.0" layoutY="60.0" prefHeight="280.0" prefWidth="600.0" style="-fx-font-size: 14px;">
            <columns>
                <TableColumn fx:id="id" prefWidth="75.0" text="Bill ID" />
                <TableColumn fx:id="dateOfTransaction" prefWidth="148.0" text="Date Of Transaction" />
                <TableColumn fx:id="type" prefWidth="85.0" text="Type" />
                <TableColumn fx:id="price" prefWidth="87.0" text="Price" />
                <TableColumn fx:id="orderId" prefWidth="77.0" text="Order ID" />
                <TableColumn fx:id="actions" prefWidth="126.0" text="Actions" />
            </columns>
        </TableView>

        <!-- Bill Statistics Panel -->
        <GridPane layoutX="50.0" layoutY="360.0" prefWidth="600.0" hgap="30.0" vgap="10.0">
            <children>
                <Label text="Max Bill Value:" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #343a40;" GridPane.columnIndex="0" />
                <Label fx:id="maxBillLabel" text="\$0.00" style="-fx-font-size: 14px;" GridPane.columnIndex="1" />

                <Label text="Min Bill Value:" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #343a40;" GridPane.columnIndex="2" />
                <Label fx:id="minBillLabel" text="\$0.00" style="-fx-font-size: 14px;" GridPane.columnIndex="3" />

                <Label text="Total Bills:" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #343a40;" GridPane.columnIndex="4" />
                <Label fx:id="billCountLabel" text="0" style="-fx-font-size: 14px;" GridPane.columnIndex="5" />
            </children>
        </GridPane>

        <!-- Button -->
        <Button fx:id="btnId" layoutX="290.0" layoutY="430.0" onAction="#onClick" text="➕ Add Bill"
                prefHeight="34.0" prefWidth="120.0"
                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" />

    </children>
</AnchorPane>
