<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.AddProductToOrderController">

   <children>

      <!-- Title -->
      <HBox layoutX="0.0" layoutY="10.0" prefWidth="600.0" alignment="CENTER">
         <children>
            <Label fx:id="titleLabel" text="➕ Add Product to Order"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2196F3;">
               <effect>
                  <DropShadow color="#2196F3" radius="3.0"/>
               </effect>
               <font>
                  <Font size="20.0"/>
               </font>
            </Label>
         </children>
      </HBox>

      <!-- Labels and Inputs -->
      <Label layoutX="100.0" layoutY="90.0" style="-fx-font-size: 16px; -fx-text-fill: #343a40;" text="Product:"/>
      <ComboBox fx:id="productComboBox" layoutX="220.0" layoutY="85.0" prefHeight="34.0" prefWidth="250.0"
                style="-fx-font-size: 14px; -fx-background-radius: 6; -fx-border-color: #2196F3; -fx-border-radius: 6;" />

      <Label layoutX="100.0" layoutY="140.0" style="-fx-font-size: 16px; -fx-text-fill: #343a40;" text="Selling Price:"/>
      <Label fx:id="sellingPriceLabel" layoutX="220.0" layoutY="140.0" prefHeight="30.0" prefWidth="250.0"
             text="Select a product" textFill="#666666"
             style="-fx-font-size: 14px;" />

      <Label layoutX="100.0" layoutY="190.0" style="-fx-font-size: 16px; -fx-text-fill: #343a40;" text="Quantity:"/>
      <TextField fx:id="quantityField" layoutX="220.0" layoutY="185.0" prefHeight="34.0" prefWidth="250.0"
                 style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #2196F3; -fx-border-radius: 6;" />

      <!-- Error Message -->
      <Label fx:id="errorLabel" layoutX="50.0" layoutY="240.0" prefHeight="34.0" prefWidth="500.0"
             style="-fx-text-fill: red; -fx-font-size: 15px;" />

      <!-- Buttons -->
      <HBox layoutX="170.0" layoutY="300.0" spacing="20.0">
         <children>
            <Button fx:id="cancelBtn" onAction="#cancelClicked" prefHeight="34.0" prefWidth="120.0"
                    text="✖ Cancel"
                    style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 6;" />

            <Button fx:id="addBtn" onAction="#addProduct" prefHeight="34.0" prefWidth="120.0"
                    text="✔ Add"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 6;" />
         </children>
      </HBox>

   </children>
</AnchorPane>
