<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.BillsInfoSaveController">

   <children>

      <!-- Page Title -->
      <Label layoutX="160.0" layoutY="30.0" prefHeight="40.0" prefWidth="300.0" style="-fx-font-size: 20px; -fx-text-fill: #007BFF; -fx-font-weight: bold;" text="Management Bills" textFill="#061736">
         <effect>
            <DropShadow color="#007BFF" radius="3.0"/>
         </effect>
         <font>
            <Font size="20.0" />
         </font>
      </Label>

      <!-- Labels -->
      <Label layoutX="80.0" layoutY="85.0" prefHeight="30.0" prefWidth="180.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Date of Transaction:"/>
      <Label layoutX="170.0" layoutY="140.0" prefHeight="30.0" prefWidth="60.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Type:"/>
      <Label layoutX="170.0" layoutY="190.0" prefHeight="30.0" prefWidth="60.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Price:"/>
      <Label layoutX="140.0" layoutY="240.0" prefHeight="30.0" prefWidth="90.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Order ID:"/>

      <!-- Input Fields -->
      <DatePicker fx:id="dateOfTransaction" layoutX="280.0" layoutY="80.0" prefHeight="34.0" prefWidth="230.0" style="-fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;"/>
      <TextField fx:id="type" layoutX="280.0" layoutY="135.0" prefHeight="34.0" prefWidth="230.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;"/>
      <TextField fx:id="price" layoutX="280.0" layoutY="185.0" prefHeight="34.0" prefWidth="230.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;"/>
      <ComboBox fx:id="orderComboBox" layoutX="280.0" layoutY="235.0" prefHeight="34.0" prefWidth="230.0" style="-fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;"/>

      <!-- Error Label -->
      <Label fx:id="errorLabel" layoutX="80.0" layoutY="290.0" prefHeight="30.0" prefWidth="440.0" style="-fx-text-fill: red; -fx-font-size: 15px;" />

      <!-- Buttons -->
      <Button fx:id="closeBtn" layoutX="170.0" layoutY="350.0" onAction="#closeClicked" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="✖ Close" />
      <Button fx:id="saveBtn" layoutX="340.0" layoutY="350.0" onAction="#save" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="💾 Save" />

   </children>
</AnchorPane>
