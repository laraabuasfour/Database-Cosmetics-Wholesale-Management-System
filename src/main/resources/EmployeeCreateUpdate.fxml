<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.EmployeeInfoSaveController">

   <children>

      <!-- Page Title -->
      <Label layoutX="160.0" layoutY="20.0" prefHeight="40.0" prefWidth="300.0" style="-fx-font-size: 20px; -fx-text-fill: #007BFF; -fx-font-weight: bold;" text="Management Employees">
         <effect>
            <DropShadow color="#007BFF" radius="3.0"/>
         </effect>
         <font>
            <Font size="20.0" />
         </font>
      </Label>

      <!-- Labels -->
      <Label layoutX="150.0" layoutY="75.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Name:"/>
      <Label layoutX="120.0" layoutY="125.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Phone Number:"/>
      <Label layoutX="150.0" layoutY="175.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Salary:"/>
      <Label layoutX="140.0" layoutY="225.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Birth Date:"/>
      <Label layoutX="150.0" layoutY="275.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Role:"/>

      <!-- Input Fields -->
      <TextField fx:id="name" layoutX="280.0" layoutY="70.0" prefHeight="34.0" prefWidth="230.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />
      <TextField fx:id="phoneNum" layoutX="280.0" layoutY="120.0" prefHeight="34.0" prefWidth="230.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />
      <TextField fx:id="salary" layoutX="280.0" layoutY="170.0" prefHeight="34.0" prefWidth="230.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />
      <DatePicker fx:id="birthDate" layoutX="280.0" layoutY="220.0" prefHeight="34.0" prefWidth="230.0" style="-fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />
      <TextField fx:id="role" layoutX="280.0" layoutY="270.0" prefHeight="34.0" prefWidth="230.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Error Label -->
      <Label fx:id="errorLabel" layoutX="50.0" layoutY="315.0" prefHeight="34.0" prefWidth="500.0" style="-fx-text-fill: red; -fx-font-size: 15px;" />

      <!-- Buttons -->
      <Button fx:id="closeButton" layoutX="170.0" layoutY="370.0" onAction="#closeClicked" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="✖ Close" />
      <Button fx:id="saveButton" layoutX="340.0" layoutY="370.0" onAction="#save" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="💾 Save" />

   </children>
</AnchorPane>
