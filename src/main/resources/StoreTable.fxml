<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Store Table UI layout -->

<BorderPane style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.StoreTableController">

    <!-- Top section: title and search -->
    <top>
        <VBox alignment="CENTER" spacing="10" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20" />
            </padding>

            <!-- Page Title -->
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #343a40;" text="Store Information">
                <effect>
                    <DropShadow color="#007BFF" radius="4" />
                </effect>
            </Label>

            <!-- Search bar and button -->
            <HBox alignment="CENTER" spacing="10">
                <!-- Text field to search by phone number -->
                <TextField fx:id="searchField" promptText="Search by phone number" style="-fx-pref-width: 200px;                   -fx-font-size: 14px;                   -fx-background-color: #001f3f;                   -fx-text-fill: white;                   -fx-border-color: #001f3f;                   -fx-border-radius: 6;                   -fx-background-radius: 6;" />


                <!-- Search button -->
                <Button fx:id="searchButton" onAction="#onSearchClick" style="-fx-background-color: #001f3f; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 6;" text="Search">
                    <effect>
                        <DropShadow color="#000f20" radius="3.0" />
                    </effect>
                </Button>
            </HBox>
        </VBox>
    </top>

    <!-- Center section: table with store data -->
    <center>
        <VBox alignment="CENTER" spacing="10">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <!-- TableView for displaying store information -->
            <TableView fx:id="storeTable" prefHeight="300" prefWidth="700" style="-fx-background-color: white; -fx-border-color: #001f3f; -fx-border-radius: 5; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <columns>
                    <!-- Store name column -->
                    <TableColumn fx:id="stname" prefWidth="172.8000431060791" text="Store Name" />
                    <!-- Phone number column -->
                    <TableColumn fx:id="stnum" prefWidth="180.00006103515625" text="Phone Number" />
                    <!-- Location column -->
                    <TableColumn fx:id="locationColumn" prefWidth="169.60006713867188" text="Location" />
                    <!-- Action buttons column (Edit/Delete) -->
                    <TableColumn fx:id="actions" prefWidth="176.79998779296875" text="Actions" />
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- Bottom section: Add and Stats buttons -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20" top="20" />
            </padding>

            <!-- Add new store button -->
            <Button fx:id="addButton" onAction="#onAddClick" style="-fx-background-color: #007BFF; -fx-text-fill: white; -fx-font-size: 14px; -fx-pref-width: 140; -fx-pref-height: 40; -fx-background-radius: 10;" text="➕ Add Store">
                <effect>
                    <DropShadow color="#0056b3" radius="3.0" />
                </effect>
            </Button>

            <!-- Show statistics button -->
            <Button fx:id="statsBtn" onAction="#openStatsView" style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-font-size: 14px; -fx-pref-width: 160; -fx-pref-height: 40; -fx-background-radius: 10;" text="📊 Display Statistics">
                <effect>
                    <DropShadow color="#117a8b" radius="3.0" />
                </effect>
            </Button>
        </HBox>
    </bottom>
</BorderPane>
