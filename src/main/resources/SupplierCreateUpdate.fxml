<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="620.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.SupplierInfoSaveController">
   <children>

      <!-- Title -->
      <Label alignment="CENTER" layoutX="135.0" layoutY="31.0" prefHeight="40.0" prefWidth="350.0" style="-fx-font-size: 20px; -fx-text-fill: #007BFF; -fx-font-weight: bold;" text="Add New Supplier Information">
         <effect>
            <DropShadow color="#007BFF" radius="3.0" />
         </effect>
         <font>
            <Font size="20.0" />
         </font>
      </Label>

      <!-- Name Field -->
      <Label layoutX="101.0" layoutY="100.0" prefHeight="27.0" prefWidth="100.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Name:">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="name" layoutX="270.0" layoutY="95.0" prefHeight="38.0" prefWidth="251.0" promptText="Enter supplier name" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Phone Number Field -->
      <Label layoutX="101.0" layoutY="180.0" prefHeight="30.0" prefWidth="157.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Phone Number:">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="phoneNumber" layoutX="270.0" layoutY="176.0" prefHeight="38.0" prefWidth="251.0" promptText="Enter phone number" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Location Field -->
      <Label layoutX="101.0" layoutY="260.0" prefHeight="30.0" prefWidth="100.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Location:">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="supplierLocation" layoutX="270.0" layoutY="256.0" prefHeight="38.0" prefWidth="251.0" promptText="Enter supplier location" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Error Message -->
      <Label fx:id="errorLabel" layoutX="118.0" layoutY="305.0" prefHeight="42.0" prefWidth="402.0" style="-fx-text-fill: red; -fx-font-size: 15px;" textAlignment="CENTER" />

      <!-- Buttons -->
      <Button fx:id="closeBtn" layoutX="180.0" layoutY="365.0" onAction="#closeClicked" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="✖ Close" />

      <Button fx:id="saveBtn" layoutX="350.0" layoutY="365.0" onAction="#save" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="💾 Save" />

   </children>
</AnchorPane>
