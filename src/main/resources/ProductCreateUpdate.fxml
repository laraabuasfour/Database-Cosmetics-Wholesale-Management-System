<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.ProductInfoSaveController">
   <children>

      <!-- Page Title -->
      <Label layoutX="150.0" layoutY="20.0" prefHeight="40.0" prefWidth="320.0" text="Management Products" style="-fx-font-size: 20px; -fx-text-fill: #007BFF; -fx-font-weight: bold;">
         <effect>
            <DropShadow color="#007BFF" radius="3.0"/>
         </effect>
      </Label>

      <!-- Labels -->
      <Label layoutX="120.0" layoutY="75.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Name:" />
      <Label layoutX="120.0" layoutY="130.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Selling Price:" />
      <Label layoutX="120.0" layoutY="185.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Buying Price:" />
      <Label layoutX="120.0" layoutY="240.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Expiring Date:" />
      <Label layoutX="120.0" layoutY="295.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Quantity:" />

      <!-- TextFields and DatePicker -->
      <TextField fx:id="name" layoutX="280.0" layoutY="70.0" prefHeight="34.0" prefWidth="200.0" style="-fx-font-size: 14px; -fx-border-radius: 6; -fx-border-color: #001f3f;" />
      <TextField fx:id="sellingPrice" layoutX="280.0" layoutY="125.0" prefHeight="34.0" prefWidth="200.0" style="-fx-font-size: 14px; -fx-border-radius: 6; -fx-border-color: #001f3f;" />
      <TextField fx:id="buyingPrice" layoutX="280.0" layoutY="180.0" prefHeight="34.0" prefWidth="200.0" style="-fx-font-size: 14px; -fx-border-radius: 6; -fx-border-color: #001f3f;" />
      <DatePicker fx:id="expiringDate" layoutX="280.0" layoutY="235.0" prefHeight="34.0" prefWidth="200.0" style="-fx-font-size: 14px; -fx-border-radius: 6; -fx-border-color: #001f3f;" />
      <TextField fx:id="quantity" layoutX="280.0" layoutY="290.0" prefHeight="34.0" prefWidth="200.0" style="-fx-font-size: 14px; -fx-border-radius: 6; -fx-border-color: #001f3f;" />

      <!-- Error Label -->
      <Label fx:id="errorLabel" layoutX="40.0" layoutY="355.0" prefHeight="34.0" prefWidth="520.0" style="-fx-text-fill: red; -fx-font-size: 15px;" />

      <!-- Buttons -->
      <Button fx:id="closeButton" layoutX="160.0" layoutY="410.0" onAction="#closeClicked" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="✖ Close" />
      <Button fx:id="saveButton" layoutX="330.0" layoutY="410.0" onAction="#save" prefHeight="36.0" prefWidth="90.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="💾 Save" />

   </children>
</AnchorPane>
