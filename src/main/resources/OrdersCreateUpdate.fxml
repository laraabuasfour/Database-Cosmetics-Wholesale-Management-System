<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>

<AnchorPane prefHeight="430.0" prefWidth="620.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.OrdersInfoSaveController">
   <children>

      <!-- Page Title -->
      <Label layoutX="160.0" layoutY="20.0" prefHeight="40.0" prefWidth="300.0" style="-fx-font-size: 20px; -fx-text-fill: #007BFF; -fx-font-weight: bold;" text="Management Orders">
         <effect>
            <DropShadow color="#007BFF" radius="3.0"/>
         </effect>
         <font>
            <Font size="20.0" />
         </font>
      </Label>

      <!-- Labels -->
      <Label layoutX="110.0" layoutY="96.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Store Name:"/>
      <Label layoutX="110.0" layoutY="162.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Employee:"/>
      <Label layoutX="110.0" layoutY="228.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Order Date:"/>

      <!-- ComboBoxes and DatePicker -->
      <ComboBox fx:id="storeComboBox" layoutX="260.0" layoutY="93.0" prefHeight="34.0" prefWidth="250.0" style="-fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />
      <ComboBox fx:id="employeeComboBox" layoutX="260.0" layoutY="159.0" prefHeight="34.0" prefWidth="250.0" style="-fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />
      <DatePicker fx:id="orderDate" layoutX="260.0" layoutY="225.0" prefHeight="34.0" prefWidth="250.0" style="-fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Error Label -->
      <Label fx:id="errorLabel" layoutX="50.0" layoutY="280.0" prefHeight="34.0" prefWidth="520.0" style="-fx-text-fill: red; -fx-font-size: 15px;" />

      <!-- Buttons -->
      <Button fx:id="closeBtn" layoutX="170.0" layoutY="340.0" onAction="#closeClicked" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="✖ Close" />
      <Button fx:id="saveBtn" layoutX="340.0" layoutY="340.0" onAction="#save" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="💾 Save" />

   </children>
</AnchorPane>
