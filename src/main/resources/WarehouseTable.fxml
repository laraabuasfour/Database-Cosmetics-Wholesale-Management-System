<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f8f9fa;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="com.db.controllers.WarehouseTableController">

    <!-- Top: Title -->
    <top>
        <VBox alignment="CENTER" spacing="5" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20" />
            </padding>


            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #343a40;" text="Warehouse Information">
                <effect>
                    <DropShadow color="#007BFF" radius="4" />
                </effect>
            </Label>



        </VBox>
    </top>

    <!-- Center: Table -->
    <center>
        <VBox alignment="CENTER" spacing="10">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <TableView fx:id="warehouseTable" prefHeight="400" prefWidth="700" style="-fx-background-color: #001f3f; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-effect: dropshadow(two-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <columns>
                    <TableColumn fx:id="warehouseid" prefWidth="163.1999454498291" text="Warehouse ID" />
                    <TableColumn fx:id="warehouse_location" prefWidth="188.800048828125" text="Location" />
                    <TableColumn fx:id="warehouse_capacity" prefWidth="171.20004272460938" text="Capacity" />
                    <TableColumn fx:id="actions" prefWidth="173.5999755859375" text="Actions" />
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- Bottom: Buttons -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20" top="20" />
            </padding>

            <Button fx:id="warehousebut" onAction="#onClick" style="-fx-background-color: #007BFF; -fx-text-fill: white; -fx-font-size: 14px; -fx-pref-width: 160; -fx-pref-height: 40; -fx-background-radius: 10;" text="➕ Add Warehouse">
                <effect>
                    <DropShadow color="#0056b3" radius="3.0" />
                </effect>
            </Button>
            <!-- Query1 -->
            <Button fx:id="showChartBtn" onAction="#showChart" style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-font-size: 14px; -fx-pref-width: 160; -fx-pref-height: 40; -fx-background-radius: 10;" text="📊 View Chart">
                <effect>
                    <DropShadow color="#117a8b" radius="3.0" />
                </effect>
            </Button>
            <!-- Query 2 -->
            <Button onAction="#showTop5Warehouses" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-pref-width: 180; -fx-pref-height: 40; -fx-background-radius: 10;" text="🏆 Top 5 Warehouses">
                <effect>
                    <DropShadow color="#1e7e34" radius="3.0" />
                </effect>
            </Button>
        </HBox>
    </bottom>
</BorderPane>
