<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.EmployeeTableController">
    <children>

        <!-- Centered Title -->
        <HBox alignment="CENTER" layoutY="15.0" prefWidth="1000.0">
            <children>
                <Label style="-fx-font-size: 24px; -fx-text-fill: #4CAF50; -fx-font-weight: bold;" text="👥 Employees Management">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>
            </children>
        </HBox>

        <!-- Search Bar -->
        <HBox layoutX="46.0" layoutY="60.0" prefHeight="40.0" spacing="10.0">
            <children>
                <Label style="-fx-font-size: 14px;" text="Search by Name:" />
                <TextField fx:id="searchField" prefWidth="200.0" promptText="Enter employee name..." />
                <Button fx:id="searchButton" onAction="#onSearch" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 8;" text="🔍 Search" />
                <Button fx:id="clearButton" onAction="#onClear" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-background-radius: 8;" text="❌ Clear" />
            </children>
        </HBox>

        <!-- Table -->
        <TableView fx:id="employeeTable" layoutX="46.0" layoutY="110.0" prefHeight="210.0" prefWidth="908.0" style="-fx-font-size: 14px;">
            <columns>
                <TableColumn fx:id="eid" prefWidth="48.0" text="E_ID" />
                <TableColumn fx:id="ename" prefWidth="174.0" text="E_Name" />
                <TableColumn fx:id="phoneNum" prefWidth="142.0" text="Phone Number" />
                <TableColumn fx:id="salary" prefWidth="117.0" text="Salary" />
                <TableColumn fx:id="birthDate" prefWidth="135.0" text="BirthDate" />
                <TableColumn fx:id="role" prefWidth="145.0" text="Role" />
                <TableColumn fx:id="actions" prefWidth="145.0" text="Action" />
            </columns>
        </TableView>

        <!-- Add Button -->
        <Button fx:id="addButton" layoutX="454.0" layoutY="330.0" mnemonicParsing="false" onAction="#onClick" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8;" text="➕ Add Employee" />

        <!-- Bar Chart -->
        <BarChart fx:id="ordersChart" layoutX="46.0" layoutY="390.0" prefHeight="280.0" prefWidth="900.0">
            <xAxis>
                <CategoryAxis fx:id="monthAxis" side="BOTTOM" />
            </xAxis>
            <yAxis>
                <NumberAxis fx:id="orderCountAxis" side="LEFT" />
            </yAxis>
        </BarChart>

    </children>
</AnchorPane>
