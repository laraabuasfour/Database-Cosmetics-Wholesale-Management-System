<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.StoreInfoSaveController">

   <children>

      <!-- Title -->
      <Label layoutX="160.0" layoutY="25.0" prefHeight="40.0" prefWidth="300.0" style="-fx-font-size: 20px; -fx-text-fill: #007BFF; -fx-font-weight: bold;" text="Add New Store Information">
         <effect>
            <DropShadow color="#007BFF" radius="3.0" />
         </effect>
         <font>
            <Font size="20.0" />
         </font>
      </Label>

      <!-- Name Field -->
      <Label layoutX="125.0" layoutY="80.0" prefHeight="30.0" prefWidth="120.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Name">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="name" layoutX="290.0" layoutY="80.0" prefHeight="35.0" prefWidth="200.0"
                 style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px;
                        -fx-border-color: #001f3f; -fx-border-radius: 5; -fx-background-radius: 5;" />

      <!-- Phone Number Field -->
      <Label layoutX="125.0" layoutY="140.0" prefHeight="30.0" prefWidth="120.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Phone Number">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="phonenum" layoutX="290.0" layoutY="140.0" prefHeight="35.0" prefWidth="200.0"
                 style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px;
                        -fx-border-color: #001f3f; -fx-border-radius: 5; -fx-background-radius: 5;" />

      <!-- Location Field -->
      <Label layoutX="125.0" layoutY="200.0" prefHeight="30.0" prefWidth="120.0" style="-fx-font-size: 18px; -fx-text-fill: #343a40;" text="Location">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="locationField" layoutX="290.0" layoutY="200.0" prefHeight="35.0" prefWidth="200.0"
                 style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px;
                        -fx-border-color: #001f3f; -fx-border-radius: 5; -fx-background-radius: 5;" />

      <!-- Error Label -->
      <Label fx:id="errorLablel" layoutX="135.0" layoutY="260.0" prefHeight="30.0" prefWidth="330.0"
             style="-fx-text-fill: red; -fx-font-size: 15px;" textAlignment="CENTER" />

      <!-- Buttons -->
      <Button fx:id="closebut" layoutX="150.0" layoutY="310.0" prefHeight="34.0" prefWidth="90.0"
              onAction="#closeClicked" text="✖ Close"
              style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" />

      <Button fx:id="savebut" layoutX="360.0" layoutY="310.0" prefHeight="34.0" prefWidth="90.0"
              onAction="#save" text="💾 Save"
              style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" />

   </children>
</AnchorPane>
