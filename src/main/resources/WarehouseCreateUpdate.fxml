<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.db.controllers.WarehouseInfoSaveController">

   <children>

      <!-- Page Title -->
      <Label layoutX="148.0" layoutY="41.0" prefHeight="40.0" prefWidth="320.0" style="-fx-font-size: 20px; -fx-text-fill: #007BFF; -fx-font-weight: bold;" text="Add New Warehouse Information" textFill="#061736">
         <effect>
            <DropShadow color="#007BFF" radius="3.0" />
         </effect>
         <font>
            <Font size="20.0" />
         </font>
      </Label>

      <!-- Location Field -->
      <TextField fx:id="warehouse_locat" layoutX="300.0" layoutY="111.0" prefHeight="42.0" prefWidth="209.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Capacity Field -->
      <TextField fx:id="warehouse_cap" layoutX="299.0" layoutY="192.0" prefHeight="42.0" prefWidth="210.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-font-size: 14px; -fx-border-color: #001f3f; -fx-border-radius: 5;" />

      <!-- Labels -->
      <Label layoutX="148.0" layoutY="107.0" prefHeight="50.0" prefWidth="90.0" style="-fx-font-size: 20px; -fx-text-fill: #343a40;" text="Location">
         <font>
            <Font size="20.0" />
         </font></Label>

      <Label layoutX="151.0" layoutY="192.0" prefHeight="42.0" prefWidth="84.0" style="-fx-font-size: 20px; -fx-text-fill: #343a40;" text="Capacity">
         <font>
            <Font size="20.0" />
         </font></Label>

      <!-- Error Message -->
      <Label fx:id="errorLabel" layoutX="148.0" layoutY="263.0" prefHeight="42.0" prefWidth="335.0" style="-fx-text-fill: red; -fx-font-size: 15px;" />

      <!-- Buttons -->
      <Button fx:id="closeBtn" layoutX="170.0" layoutY="324.0" onAction="#closeClicked" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="✖ Close" />

      <Button fx:id="saveBtn" layoutX="350.0" layoutY="324.0" onAction="#save" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10;" text="💾 Save" />

   </children>
</AnchorPane>
